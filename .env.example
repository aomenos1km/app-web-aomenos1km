# Aomenos1km — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais

# ==============================================
# BANCO DE DADOS (Vercel Postgres)
# Obtido no dashboard: vercel.com → Storage → Postgres → Connect
# ==============================================
POSTGRES_URL="postgres://usuario:senha@host:5432/database?sslmode=require"
POSTGRES_PRISMA_URL="postgres://usuario:senha@host:5432/database?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://usuario:senha@host:5432/database?sslmode=require"

# ==============================================
# JWT (Segredo para assinar os tokens)
# Gere com: openssl rand -base64 32
# ==============================================
JWT_SECRET="SUBSTITUA_POR_UMA_STRING_ALEATORIA_MUITO_LONGA_E_SECRETA"
JWT_EXPIRATION_HOURS=24

# ==============================================
# CLOUDINARY (Storage de imagens)
# Obtido em: cloudinary.com → Dashboard → API Keys
# ==============================================
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="seu_api_secret"

# ==============================================
# PIX / GATEWAY DE PAGAMENTO (Asaas)
# Obtido em: asaas.com → Integrações → API
# ==============================================
ASAAS_API_KEY="seu_asaas_api_key"
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"   # trocar para https://api.asaas.com/api/v3 em produção

# ==============================================
# WHATSAPP BUSINESS API
# Obtido no Meta for Developers → WhatsApp
# ==============================================
WHATSAPP_PHONE_NUMBER_ID="seu_phone_number_id"
WHATSAPP_ACCESS_TOKEN="seu_access_token"
WHATSAPP_VERIFY_TOKEN="sua_string_verificacao_webhook"
WHATSAPP_API_VERSION="v18.0"

# Número do admin para receber alertas de ocupação (com DDI: +5511999999999)
WHATSAPP_ADMIN_NUMBER="+5511999999999"

# ==============================================
# BACKEND
# ==============================================
BACKEND_URL="http://localhost:8080"   # trocar para URL do Vercel em produção
PORT=8080
GIN_MODE="debug"   # trocar para "release" em produção

# ==============================================
# FRONTEND (Next.js)
# Prefixar variáveis públicas com NEXT_PUBLIC_
# ==============================================
NEXT_PUBLIC_API_URL="http://localhost:8080"   # trocar para URL do backend em produção
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="seu_cloud_name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="aomenos1km_upload"  # preset sem assinatura do Cloudinary
